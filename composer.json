{
    "name": "fadhila36/pakasir-sdk",
    "description": "Laravel Package for Pakasir Payment Gateway",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Fadhila36",
            "email": "fadhila36@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Fadhila36\\Pakasir\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fadhila36\\Pakasir\\PakasirServiceProvider"
            ],
            "aliases": {
                "Pakasir": "Fadhila36\\Pakasir\\Facades\\Pakasir"
            }
        }
    },
    "minimum-stability": "stable",
    "require-dev": {
        "orchestra/testbench": "^8.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Fadhila36\\Pakasir\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
