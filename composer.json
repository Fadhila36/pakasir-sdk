{
    "name": "fadhila36/pakasir-sdk",
    "description": "Laravel Package for Pakasir Payment Gateway",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Muhammad Fadhila Abiyyu Faris",
            "email": "fadhilaabiyyu@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "keywords": [
        "laravel",
        "php",
        "sdk",
        "payment-gateway",
        "pakasir",
        "laravel-package",
        "api-client",
        "fintech",
        "indonesia"
    ],
    "autoload": {
        "psr-4": {
            "Fadhila36\\Pakasir\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fadhila36\\Pakasir\\PakasirServiceProvider"
            ],
            "aliases": {
                "Pakasir": "Fadhila36\\Pakasir\\Facades\\Pakasir"
            }
        }
    },
    "minimum-stability": "stable",
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "laravel/pint": "^1.15",
        "phpstan/phpstan": "^1.11"
    },
    "autoload-dev": {
        "psr-4": {
            "Fadhila36\\Pakasir\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}